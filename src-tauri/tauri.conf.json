{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "sportspulse",
  "version": "0.1.0",
  "identifier": "com.sportspulse.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SportsPulse Scoreboard",
        "width": 340,
        "height": 110,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "mini_popup",
        "title": "sportspulse-alert",
        "width": 278,
        "height": 68,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "url": "mini_popup.html"
      },
      {
        "label": "dashboard",
        "title": "SportsPulse Dashboard",
        "width": 650,
        "height": 450,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": true,
        "url": "dashboard.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
